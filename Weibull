        "Funciòn CDF empìrica"
      ],
      "metadata": {
        "id": "EJwkKNRjfpQz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def cdf(m):\n",
        "  n = len(m)\n",
        "  x = np.sort(m)\n",
        "  y = np.arange(0,n)/n\n",
        "  return x, y\n",
        "\n",
        "x_math, y_math = cdf(m)"
      ],
      "metadata": {
        "id": "0SlP3cG3dzsd"
      },
      "execution_count": 27,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Calcular media"
      ],
      "metadata": {
        "id": "gJdJMc_4f28b"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "media = np.mean(m)"
      ],
      "metadata": {
        "id": "DL95gLBteOnV"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Gràfica CDF"
      ],
      "metadata": {
        "id": "sHDllSfcf5Zz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "plt.step(x_math, y_math)\n",
        "plt.axhline(y=0.5, color='r')\n",
        "plt.axvline(x=media, color='green')\n",
        "plt.title(\"CDF Weibull\")\n",
        "plt.show()"
