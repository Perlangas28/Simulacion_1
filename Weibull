        "#Mètodo de la Transformada Inversa: Weibull\n"
      ],
      "metadata": {
        "id": "WUSgCKRmVvnO"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "Pseudocòdigo:\n",
        "\n",
        "Repetir:\n",
        "\n",
        "1. Generar U ~(0,1)\n",
        "2. Hacer:\n",
        "   X = (-ln(1-U))^(1/alpha)\n",
        "3. Devolver X\n"
      ],
      "metadata": {
        "id": "TpHFXHrYWcrW"
      }
    },
    {
      "cell_type": "code",
      "execution_count": 18,
      "metadata": {
        "id": "Aiw0GxMSVusx"
      },
      "outputs": [],
      "source": [
        "import random as r\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Generador Weibull"
      ],
      "metadata": {
        "id": "R48lQCXJfeYd"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def weibull(n, alpha):\n",
        "  l = []\n",
        "  for i in range(n):\n",
        "    u = r.random()\n",
        "    x = (-np.log(1-u))**(1/alpha)\n",
        "    l.append(x)\n",
        "  return l"
      ],
      "metadata": {
        "id": "GjIihQysXPj1"
      },
      "execution_count": 22,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Generador de muestra"
      ],
      "metadata": {
        "id": "7BNugiyGfjIj"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "m = weibull(100000, 2)"
      ],
